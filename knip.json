{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "@evilmartians/lefthook",
        "better-typescript-lib",
        "textlint-rule-no-dead-link",
        "textlint-rule-preset-ja-technical-writing"
      ]
    },
    "packages/benchmark": {
      "entry": ["*.bench.ts", "setup/*.ts"],
      "project": ["**/*.ts"]
    },
    "website": {
      "entry": ["src/entry-server.tsx", "plugins/*.ts"],
      "ignoreDependencies": ["babel-plugin-react-compiler", "lightningcss"]
    }
  },
  "ignore": ["website/src/components/PackageInstall/**"],
  "ignoreBinaries": ["stylelint", "markdownlint-cli2", "textlint"],
  "ignoreUnresolved": ["/pagefind/pagefind.js"]
}
