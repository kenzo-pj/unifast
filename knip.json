{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "@evilmartians/lefthook",
        "@vitest/coverage-v8",
        "better-typescript-lib",
        "textlint-rule-no-dead-link",
        "textlint-rule-preset-ja-technical-writing"
      ]
    },
    "packages/benchmark": {
      "entry": ["*.bench.ts", "setup/*.ts"],
      "project": ["**/*.ts"]
    },
    "packages/vite": {
      "ignoreDependencies": ["@unifast/node"]
    },
    "website": {
      "entry": ["src/entry-server.tsx", "plugins/*.ts"],
      "ignoreDependencies": ["babel-plugin-react-compiler", "lightningcss"]
    }
  }
}
