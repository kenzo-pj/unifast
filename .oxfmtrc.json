{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "embeddedLanguageFormatting": "auto",
  "sortImports": {},
  "sortPackageJson": true,
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "*.gen.ts"
  ]
}
