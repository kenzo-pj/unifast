{
  "name": "unifast-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "lint": "turbo lint:oxc typecheck lint:css lint:md lint:text && cargo clippy --all-targets --all-features -- -D warnings",
    "lint:fix": "turbo lint:oxc:fix lint:css:fix lint:md:fix lint:text:fix && cargo clippy --fix --all-targets --all-features --allow-dirty",
    "lint:oxc": "turbo lint:oxc",
    "lint:oxc:fix": "turbo lint:oxc:fix",
    "lint:rust": "cargo clippy --all-targets --all-features -- -D warnings",
    "lint:rust:fix": "cargo clippy --fix --all-targets --all-features --allow-dirty",
    "lint:css": "turbo lint:css",
    "lint:css:fix": "turbo lint:css:fix",
    "lint:md": "turbo lint:md",
    "lint:md:fix": "turbo lint:md:fix",
    "lint:text": "turbo lint:text",
    "lint:text:fix": "turbo lint:text:fix",
    "typecheck": "turbo typecheck",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "fmt": "turbo fmt:oxc && cargo fmt --all",
    "fmt:check": "turbo fmt:oxc:check && cargo fmt --all -- --check",
    "fmt:oxc": "turbo fmt:oxc",
    "fmt:oxc:check": "turbo fmt:oxc:check",
    "fmt:rust": "cargo fmt --all",
    "fmt:rust:check": "cargo fmt --all -- --check",
    "test": "turbo test",
    "build": "turbo build",
    "dev:website": "turbo dev --filter=@unifast/website",
    "build:website": "turbo build --filter=@unifast/website",
    "preview:website": "turbo preview --filter=@unifast/website",
    "bench": "turbo bench --filter=@unifast/benchmark"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@evilmartians/lefthook",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@evilmartians/lefthook": "^2.1.2",
    "better-typescript-lib": "^2.12.0",
    "knip": "^5.85.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^0.15.15",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
