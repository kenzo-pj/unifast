{
  "name": "@unifast/react",
  "version": "0.0.5",
  "description": "Convert HAST to React elements for unifast",
  "license": "MIT",
  "author": "Kenzo-Wada",
  "repository": {
    "type": "git",
    "url": "https://github.com/kenzo-pj/unifast",
    "directory": "packages/react"
  },
  "homepage": "https://kenzo-pj.github.io/unifast/",
  "bugs": {
    "url": "https://github.com/kenzo-pj/unifast/issues"
  },
  "keywords": [
    "unifast",
    "markdown",
    "mdx",
    "react",
    "hast"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "lint:oxc": "oxlint -c ../../.oxlintrc.json .",
    "lint:oxc:fix": "oxlint -c ../../.oxlintrc.json --fix .",
    "typecheck": "tsc --noEmit",
    "fmt:oxc": "oxfmt --write .",
    "fmt:oxc:check": "oxfmt --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov"
  },
  "dependencies": {
    "@unifast/core": "workspace:*",
    "@unifast/node": "workspace:*",
    "style-to-object": "^1.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
