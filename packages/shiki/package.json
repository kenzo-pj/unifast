{
  "name": "@unifast/shiki",
  "version": "0.0.5",
  "description": "Shiki syntax highlighting plugin for unifast via HAST transforms",
  "license": "MIT",
  "author": "Kenzo-Wada",
  "repository": {
    "type": "git",
    "url": "https://github.com/kenzo-pj/unifast",
    "directory": "packages/shiki"
  },
  "homepage": "https://kenzo-pj.github.io/unifast/",
  "bugs": {
    "url": "https://github.com/kenzo-pj/unifast/issues"
  },
  "keywords": [
    "unifast",
    "markdown",
    "syntax-highlighting",
    "shiki",
    "hast"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "lint:oxc": "oxlint -c ../../.oxlintrc.json .",
    "lint:oxc:fix": "oxlint -c ../../.oxlintrc.json --fix .",
    "typecheck": "tsc --noEmit",
    "fmt:oxc": "oxfmt --write .",
    "fmt:oxc:check": "oxfmt --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov"
  },
  "dependencies": {
    "@unifast/core": "workspace:*",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
