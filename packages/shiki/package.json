{
  "name": "@unifast/shiki",
  "version": "0.1.0",
  "description": "Shiki syntax highlighting plugin for unifast via HAST transforms",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "lint:oxc": "oxlint -c ../../.oxlintrc.json .",
    "lint:oxc:fix": "oxlint -c ../../.oxlintrc.json --fix .",
    "typecheck": "tsc --noEmit",
    "fmt:oxc": "oxfmt --write .",
    "fmt:oxc:check": "oxfmt --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@unifast/core": "workspace:*",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
