{
  "name": "@unifast/node",
  "version": "0.0.5",
  "description": "Node.js binding for unifast Markdown/MDX compiler",
  "keywords": [
    "compiler",
    "markdown",
    "mdx",
    "napi",
    "nodejs",
    "rust",
    "unifast"
  ],
  "homepage": "https://kenzo-pj.github.io/unifast/",
  "bugs": {
    "url": "https://github.com/kenzo-pj/unifast/issues"
  },
  "license": "MIT",
  "author": "Kenzo-Wada",
  "repository": {
    "type": "git",
    "url": "https://github.com/kenzo-pj/unifast",
    "directory": "packages/node"
  },
  "files": [
    "dist",
    "native"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "lint:oxc": "oxlint -c ../../.oxlintrc.json .",
    "lint:oxc:fix": "oxlint -c ../../.oxlintrc.json --fix .",
    "typecheck": "tsc --noEmit",
    "fmt:oxc": "oxfmt --write .",
    "fmt:oxc:check": "oxfmt --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov"
  },
  "dependencies": {
    "@unifast/core": "workspace:*",
    "deepmerge": "^4.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
