{
  "name": "@unifast/core",
  "version": "0.1.0",
  "description": "TypeScript type definitions for unifast",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "lint:oxc": "oxlint -c ../../.oxlintrc.json .",
    "lint:oxc:fix": "oxlint -c ../../.oxlintrc.json --fix .",
    "typecheck": "tsc --noEmit",
    "fmt:oxc": "oxfmt --write .",
    "fmt:oxc:check": "oxfmt --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
