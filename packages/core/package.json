{
  "name": "@unifast/core",
  "version": "0.0.3",
  "description": "TypeScript type definitions for unifast",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "lint:oxc": "oxlint -c ../../.oxlintrc.json .",
    "lint:oxc:fix": "oxlint -c ../../.oxlintrc.json --fix .",
    "typecheck": "tsc --noEmit",
    "fmt:oxc": "oxfmt --write .",
    "fmt:oxc:check": "oxfmt --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
