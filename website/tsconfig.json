{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "declaration": false,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "outDir": "dist",
    "baseUrl": ".",
    "rootDirs": [".", "generated"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src", "plugins", "scripts", "*.ts", ".astro"],
  "cmkOptions": {
    "enabled": true
  }
}
