{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "declaration": false,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "outDir": "dist",
    "baseUrl": ".",
    "rootDirs": [".", "generated"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src", "plugins", "scripts", "*.ts"],
  "cmkOptions": {
    "enabled": true
  }
}
