{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "passThroughEnv": ["GH_SPONSORS_TOKEN"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint:oxc": {},
    "lint:oxc:fix": { "cache": false },
    "lint:css": {},
    "lint:css:fix": { "cache": false },
    "lint:md": {},
    "lint:md:fix": { "cache": false },
    "lint:text": {},
    "lint:text:fix": { "cache": false },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "fmt:oxc": {},
    "fmt:oxc:check": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "bench": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
